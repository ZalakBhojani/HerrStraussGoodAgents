# GCP / VertexAI (required when provider=vertexai)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Path to service account JSON key (omit to use gcloud ADC)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# OpenAI (required when provider=openai)
OPENAI_API_KEY=sk-...

# Anthropic (required when provider=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=collections-queue

# App
APP_HOST=0.0.0.0
APP_PORT=8000
